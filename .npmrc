# Los packages con scope @wildtrip-company se resuelven y publican en GitHub Packages.
@wildtrip-company:registry=https://npm.pkg.github.com

# El token NO va acá: pnpm ignora credenciales en el .npmrc del proyecto porque
# este archivo se commitea y filtrarlo expondría el secreto. Va en uno de estos:
#
#   local:  pnpm config set "//npm.pkg.github.com/:_authToken" <TU_TOKEN>
#   CI:     actions/setup-node escribe el ~/.npmrc con NODE_AUTH_TOKEN
